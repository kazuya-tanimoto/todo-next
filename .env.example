# Local Supabase (default for development)
# Run `supabase start` then `supabase status` to get these values
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-local-anon-key>

# Google OAuth (optional, for local Google login)
# Get these from Google Cloud Console > Credentials
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=

# E2E tests (Playwright) — recommended to set in .env.local (local only, never commit)
# SUPABASE_SERVICE_ROLE_KEY: take the service_role key from `supabase status`.
# Used by the setup project to seed the test user / profile and clean up data (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=<your-local-service-role-key>
E2E_TEST_EMAIL=e2e@example.com
E2E_TEST_PASSWORD=e2e-password-123
